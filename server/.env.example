# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/legal_workspace"
DIRECT_URL="postgresql://postgres:password@localhost:5432/legal_workspace"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="change-this-to-another-long-random-secret"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# AI — Groq (server-side only, never sent to browser)
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama3-70b-8192"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=20
